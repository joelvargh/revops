{
  "name": "WF-01: Discovery Runner",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 5
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0],
      "id": "t1",
      "name": "Every 5 Min"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE discovery_run SET status = 'PENDING', \"startedAt\" = NULL WHERE status = 'RUNNING' AND \"startedAt\" < NOW() - INTERVAL '2 hours'",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [0, 0],
      "id": "q0",
      "name": "Reset Stalled Runs",
      "credentials": {
        "postgres": {
          "id": "mvx8V6R6tpqp0GEJ",
          "name": "RevOps PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH claimed AS (SELECT dr.id FROM discovery_run dr JOIN grid_cell gc ON gc.id = dr.\"gridCellId\" JOIN campaign c ON c.id = dr.\"campaignId\" WHERE dr.status = 'PENDING' AND c.status = 'ACTIVE' ORDER BY gc.row, gc.col LIMIT 1 FOR UPDATE OF dr SKIP LOCKED) UPDATE discovery_run SET status = 'RUNNING', \"startedAt\" = NOW() FROM claimed WHERE discovery_run.id = claimed.id RETURNING discovery_run.id, discovery_run.\"campaignId\", discovery_run.\"gridCellId\"",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [220, 0],
      "id": "q1",
      "name": "Claim Next Pending Run",
      "credentials": {
        "postgres": {
          "id": "mvx8V6R6tpqp0GEJ",
          "name": "RevOps PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT dr.\"campaignId\", gc.geometry, c.\"searchTerm\" FROM discovery_run dr JOIN grid_cell gc ON gc.id = dr.\"gridCellId\" JOIN campaign c ON c.id = dr.\"campaignId\" WHERE dr.id = $1",
        "additionalFields": {
          "queryParams": "={{ [$('Claim Next Pending Run').first().json.id] }}"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [440, 0],
      "id": "q1b",
      "name": "Fetch Run Details",
      "credentials": {
        "postgres": {
          "id": "mvx8V6R6tpqp0GEJ",
          "name": "RevOps PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "isNotEmpty"
              }
            }
          ]
        },
        "combineOperation": "all"
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [440, 0],
      "id": "if1",
      "name": "Has Pending?"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"UPDATE discovery_run SET status = 'RUNNING', \\\"startedAt\\\" = NOW() WHERE id = '\" + $('Get Next Pending Run').first().json.id + \"'\" }}",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [660, 0],
      "id": "q2",
      "name": "Mark Running",
      "credentials": {
        "postgres": {
          "id": "mvx8V6R6tpqp0GEJ",
          "name": "RevOps PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/solidcode~google-maps-scraper-2-5-per-1-000-results/runs",
        "sendQuery": true,
        "queryParameters": {
          "parameters": []
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ searchQueries: [$('Fetch Run Details').first().json.searchTerm], customGeolocation: $('Fetch Run Details').first().json.geometry, maxResults: 0, language: 'en', countryCode: 'US' }) }}",
        "options": {
          "timeout": 30000
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 0],
      "id": "api1",
      "name": "Start Apify Run",
      "credentials": {
        "httpQueryAuth": {
          "id": "w2KZi6AKoZhAUu7Y",
          "name": "Apify"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://api.apify.com/v2/actor-runs/' + $json.data.id + '' }}",
        "options": {
          "timeout": 10000
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, 0],
      "id": "api2",
      "name": "Poll Run Status",
      "credentials": {
        "httpQueryAuth": {
          "id": "w2KZi6AKoZhAUu7Y",
          "name": "Apify"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "c2",
              "leftValue": "={{ $json.data.status }}",
              "rightValue": "SUCCEEDED",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "combineOperation": "all"
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1320, 0],
      "id": "if2",
      "name": "Run Done?"
    },
    {
      "parameters": {
        "amount": 15,
        "unit": "seconds"
      },
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [1320, 200],
      "id": "wait1",
      "name": "Wait 15s"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://api.apify.com/v2/datasets/' + $('Poll Run Status').first().json.data.defaultDatasetId + '/items&limit=5000' }}",
        "options": {
          "timeout": 60000
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 0],
      "id": "api3",
      "name": "Fetch Dataset",
      "credentials": {
        "httpQueryAuth": {
          "id": "w2KZi6AKoZhAUu7Y",
          "name": "Apify"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const i = $json;\nconst campaignId = $('Claim Next Pending Run').first().json.campaignId;\nreturn { json: {\n  name: i.title || i.name || 'Unknown',\n  domain: i.website ? i.website.replace(/^https?:\\/\\//, '').replace(/^www\\./, '').split('/')[0] : null,\n  phone: i.phone || null,\n  placeId: i.placeId || null,\n  googleMapsUrl: i.url || null,\n  address: i.address || null,\n  city: i.city || null,\n  state: i.state || null,\n  zip: i.postalCode || null,\n  country: 'US',\n  lat: i.location?.lat || null,\n  lng: i.location?.lng || null,\n  category: i.categoryName || null,\n  categories: JSON.stringify(i.categories || []),\n  website: i.website || null,\n  rating: i.totalScore || null,\n  reviewCount: i.reviewsCount || null,\n  isClosed: i.permanentlyClosed || false,\n  source: 'google_maps',\n  campaignId: campaignId\n}};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1760, 0],
      "id": "code1",
      "name": "Map Fields"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"INSERT INTO company (id, name, domain, phone, \\\"placeId\\\", \\\"googleMapsUrl\\\", address, city, state, zip, country, lat, lng, category, categories, website, rating, \\\"reviewCount\\\", \\\"isClosed\\\", source, \\\"campaignId\\\", status) VALUES (gen_random_uuid(), '\" + ($json.name || '').replace(/'/g, \"''\") + \"', \" + ($json.domain ? \"'\" + $json.domain + \"'\" : 'NULL') + \", \" + ($json.phone ? \"'\" + $json.phone.replace(/'/g, \"''\") + \"'\" : 'NULL') + \", \" + ($json.placeId ? \"'\" + $json.placeId + \"'\" : 'NULL') + \", \" + ($json.googleMapsUrl ? \"'\" + $json.googleMapsUrl + \"'\" : 'NULL') + \", \" + ($json.address ? \"'\" + $json.address.replace(/'/g, \"''\") + \"'\" : 'NULL') + \", \" + ($json.city ? \"'\" + $json.city.replace(/'/g, \"''\") + \"'\" : 'NULL') + \", \" + ($json.state ? \"'\" + $json.state.replace(/'/g, \"''\") + \"'\" : 'NULL') + \", \" + ($json.zip ? \"'\" + $json.zip + \"'\" : 'NULL') + \", 'US', \" + ($json.lat || 'NULL') + \", \" + ($json.lng || 'NULL') + \", \" + ($json.category ? \"'\" + $json.category.replace(/'/g, \"''\") + \"'\" : 'NULL') + \", \" + ($json.categories ? \"'\" + $json.categories.replace(/'/g, \"''\") + \"'\" : \"'[]'\") + \"::text[], \" + ($json.website ? \"'\" + $json.website + \"'\" : 'NULL') + \", \" + ($json.rating || 'NULL') + \", \" + ($json.reviewCount || 'NULL') + \", \" + ($json.isClosed || false) + \", 'google_maps', '\" + $json.campaignId + \"', 'DISCOVERED') ON CONFLICT (\\\"placeId\\\") DO NOTHING\" }}",
        "options": {
          "queryBatching": "independently"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1980, 0],
      "id": "q3",
      "name": "Insert Companies",
      "credentials": {
        "postgres": {
          "id": "mvx8V6R6tpqp0GEJ",
          "name": "RevOps PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst runId = $('Claim Next Pending Run').first().json.id;\nconst total = $('Fetch Dataset').first().json.length || items.length;\nreturn [{ json: { runId, total, inserted: items.length } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2200, 0],
      "id": "code2",
      "name": "Count Results"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"UPDATE discovery_run SET status = 'COMPLETED', \\\"resultsFound\\\" = \" + $json.total + \", \\\"resultsNew\\\" = \" + $json.inserted + \", \\\"completedAt\\\" = NOW() WHERE id = '\" + $json.runId + \"'\" }}",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [2420, 0],
      "id": "q4",
      "name": "Mark Completed",
      "credentials": {
        "postgres": {
          "id": "mvx8V6R6tpqp0GEJ",
          "name": "RevOps PostgreSQL"
        }
      }
    },
    {
      "parameters": {},
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [660, 200],
      "id": "noop1",
      "name": "No Pending Jobs"
    }
  ],
